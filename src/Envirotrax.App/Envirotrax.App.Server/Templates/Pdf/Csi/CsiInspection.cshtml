@model Envirotrax.App.Server.Domain.DataTransferObjects.Csi.CsiInspectionDto
@{
    Layout = null;
    var reasonLabels = new[] {
        "New construction",
        "Existing service where contaminant hazards are suspected",
        "Major renovation or expansion of distribution facilities"
    };
    var reasonLabel = (int)Model.ReasonForInspection < reasonLabels.Length
        ? reasonLabels[(int)Model.ReasonForInspection] : "";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <style>
        body { font-size: 9.1px; font-family: Arial, sans-serif; }

        .page-title {
            background-color: #323232;
            color: #ffffff;
            font-size: 10.6px;
            font-weight: bold;
            text-align: center;
            padding: 5px 3px;
            margin-bottom: 5px;
        }

        .section-header {
            background-color: #a0a0a0;
            color: #ffffff;
            font-weight: bold;
            padding: 2.5px 5px;
            margin-top: 5px;
            text-align: center;
            border: 1px solid #323232;
        }

        .label { font-weight: bold; }

        table { width: 100%; border-collapse: collapse; }
        td { border: none; padding: 2.5px 5px; vertical-align: top; }
        th {
            border: 1px solid #323232;
            background-color: #a0a0a0;
            color: #ffffff;
            text-align: center;
            padding: 3px 6px;
            vertical-align: top;
        }

        .compliance-check { text-align: center; font-size: 14px; }
        .disapproval-box { border: 2px solid red; background: #ffe0e0; color: darkred; font-weight: bold; padding: 6px; margin-top: 8px; }
        .footer-note { font-size: 9px; font-style: italic; text-align: center; margin-top: 16px; color: #555; }
    </style>
</head>
<body>
    <div class="page-title">@Model.WaterSupplier?.Name &ndash; Customer Service Inspection</div>

    <div class="section-header">Water Supplier </div>
    <table>
        <tr>
            <td class="label" style="width:120px">Water supplier:</td>
            <td>@Model.WaterSupplier?.Name</td>
            <td class="label" style="width:110px">Contact name:</td>
            <td>@Model.WaterSupplier?.ContactName</td>
        </tr>
        <tr>
            <td class="label" style="width:120px">Address:</td>
            <td>@Model.WaterSupplier?.Address</td>
            <td class="label">Phone number:</td>
            <td>@Model.WaterSupplier?.PhoneNumber</td>
        </tr>
        <tr>
            <td class="label">PWS ID:</td>
            <td>@Model.WaterSupplier?.PwsId</td>
            <td class="label">Email address:</td>
            <td colspan="3">@Model.WaterSupplier?.EmailAddress</td>
        </tr>
    </table>

    <div class="section-header">CSI Inspector</div>
    <table>
        <tr>
            <td class="label" style="width:120px">Company name:</td>
            <td>@Model.InspectorCompanyName</td>
            <td class="label" style="width:110px">Phone number:</td>
            <td>@Model.InspectorWorkNumber</td>
        </tr>
        <tr>
            <td class="label">Title of inspector:</td>
            <td>@Model.InspectorJobTitle</td>
            <td class="label">Email address:</td>
            <td>@Model.Id</td>
        </tr>
        <tr>
            <td class="label">Inspector name:</td>
            <td>@Model.InspectorContactName</td>
            <td class="label">License number:</td>
            <td>@Model.InspectorLicenseNumber</td>
        </tr>
        <tr>
            <td class="label">Address:</td>
            <td>@Model.InspectorAddress, @Model.InspectorCity @Model.InspectorState @Model.InspectorZip</td>
            <td class="label">License type:</td>
            <td>@Model.InspectorLicenseType</td>
        </tr>
    </table>
    <table>
        <tr>
            <td class="ps-0">
                <div class="section-header">Location / Property Information</div>
                <table>
                    <tr>
                        <td class="label" style="width:120px">Property type:</td>
                        <td>@(Model.PropertyType == Envirotrax.App.Server.Data.Models.Sites.PropertyType.Commercial ? "Commercial" : "Residential")</td>
                    </tr>
                    <tr>
                        <td class="label">Business name:</td>
                        <td>@Model.PropertyBusinessName</td>
                    </tr>
                    <tr>
                        <td class="label">Property address:</td>
                        <td>@Model.PropertyStreetNumber @Model.PropertyStreetName, @Model.PropertyCity @Model.PropertyState?.Name @Model.PropertyZip</td>
                    </tr>
                </table>
            </td>
            <td class="pe-0">
                <div class="section-header">Contact / Mailing Information</div>
                <table>
                    <tr>
                        <td class="label" style="width:120px">Company name:</td>
                        <td>@Model.MailingCompanyName</td>
                    </tr>
                    <tr>
                        <td class="label">Contact name:</td>
                        <td>@Model.MailingContactName</td>
                    </tr>
                    <tr>
                        <td class="label">Mailing address:</td>
                        <td colspan="3">@Model.MailingStreetNumber @Model.MailingStreetName, @Model.MailingCity @Model.MailingState?.Name @Model.MailingZip</td>
                    </tr>
                    <tr>
                        <td class="label" style="width:110px">Phone number:</td>
                        <td>@Model.MailingPhoneNumber</td>
                    </tr>
                    <tr>
                        <td class="label">Email:</td>
                        <td>@Model.MailingEmailAddress</td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>

    <div class="section-header">Inspection Results</div>
    <table>
        <tr>
            <td><span class="label">Reason for inspection:</span> @reasonLabel</td>
            <td style="width:160px"><span class="label">Inspection date:</span> @Model.InspectionDate?.ToString("MM/dd/yyyy")</td>
        </tr>
    </table>

    <div class="p-2 mb-2 border border-3 border-secondary-subtle">
         <p style="margin:3px 0; font-size:9.1px;">
                    I, <u>@Model.InspectorContactName</u>, upon inspection of the private water distribution facilities
                    connected to the aforementioned public water supply do hereby certify that, to the best of my knowledge:
        </p>
        <table>
            <tr>
                <td></td>
                <td></td>
                <td style="width:80px">Compliance</td>
                <td style="width:100px">Non-compliance</td>
            </tr>
            @{
                var statements = new[] {
                    "No direct or indirect connection between the public drinking water supply and a potential source of contamination exists.",
                    "No cross-connection between the public drinking water supply and a private water system exists.",
                    "No connection exists which would allow the return of water used for condensing, cooling or industrial processes back to the public water supply.",
                    "No pipe or pipe fitting which contains more than 8.0% lead exists in private water distribution facilities installed on or after July 1, 1988 and prior to January 4, 2014.",
                    "Plumbing installed on or after January 4, 2014 bears the expected labeling indicating ≤0.25% lead content.",
                    "No solder or flux which contains more than 0.2% lead exists in private water distribution facilities installed on or after July 1, 1988."
                };
                var compliances = new bool[] {
                    Model.Compliance1, Model.Compliance2, Model.Compliance3,
                    Model.Compliance4, Model.Compliance5, Model.Compliance6
                };
            }
            @for (var i = 0; i < 6; i++)
            {
                <tr>
                    <td>@(i + 1).</td>
                    <td>@statements[i]</td>
                    <td class="compliance-check">@(compliances[i] ? "✓" : "○")</td>
                    <td class="compliance-check">@(!compliances[i] ? "✓" : "○")</td>
                </tr>
            }
        </table>
    </div>
    <div class="p-2 mb-2 border border-3 border-secondary-subtle">
        <p style="margin:3px 0; font-size:9.1px;">
            I further certify that the following materials were used in the installation of the private water distribution facilities:
        </p>
        <table>
            <tr>
                <td class="label" style="width:100px">Service lines:</td>
                <td>@(Model.MaterialServiceLineLead ? "✓" : "□") Lead</td>
                <td>@(Model.MaterialServiceLineCopper ? "✓" : "□") Copper</td>
                <td>@(Model.MaterialServiceLinePVC ? "✓" : "□") PVC</td>
                <td>@(Model.MaterialServiceLineOther ? $"✓ Other: {Model.MaterialServiceLineOtherDescription}" : "□ Other")</td>
            </tr>
            <tr>
                <td class="label">Solder:</td>
                <td>@(Model.MaterialSolderLead ? "✓" : "□") Lead</td>
                <td>@(Model.MaterialSolderLeadFree ? "✓" : "□") Lead free</td>
                <td>@(Model.MaterialSolderSolventWeld ? "✓" : "□") Solvent weld</td>
                <td>@(Model.MaterialSolderOther ? $"✓ Other: {Model.MaterialSolderOtherDescription}" : "□ Other")</td>
            </tr>
        </table>
    </div>

    <div class="p-2 mb-2 border border-3 border-secondary-subtle">
        <p style="margin:3px 0; font-size:9.1px;">
            ✓    I recognize that this document shall be retained by the aforementioned Public Water System for a minimum of ten years and that I am legally
            responsible for the validity of the information I have provided.
        </p>
    </div>

    <div class="section-header">Remarks</div>
    <table>
        <tr><td style="min-height:60px">@Model.Comments</td></tr>
    </table>

    @if (Model.Disapproved)
    {
        <div class="disapproval-box">DISAPPROVED &mdash; @Model.DisapprovedReason</div>
    }

    <div class="footer-note">
        A Customer Service Inspection Certificate should be on file for each connection in a public water system
        to document compliance with 30 TAC &sect;290.44(h)/290.46(j).
    </div>
</body>
</html>
